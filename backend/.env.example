# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_mom_db
DB_USER=YOUR_USER
DB_PASSWORD=YOUR_DB_PASSWORD

# JWT
JWT_SECRET=YOUR_JWT_KEY
JWT_EXPIRES_IN=7d

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OpenAI (Whisper transcription)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Google OAuth2 (for Calendar API)
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_SECRET_ID
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
GOOGLE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN

# File Paths
TEMP_DIR=./temp

# Bot Chrome paths
# For simultaneous meetings: one Google account per concurrent meeting
# Set BOT_PROFILE_DIRS (comma-separated) — one path per bot account
#
# Mac example (2 concurrent meetings):
# BOT_PROFILE_DIRS=/Users/pranav/bot-profile-1,/Users/pranav/bot-profile-2
#
# Windows example:
# BOT_PROFILE_DIRS=C:\bot-profile-1,C:\bot-profile-2
#
# Single account fallback (only if BOT_PROFILE_DIRS is not set):
# BOT_PROFILE_DIR=/Users/pranav/bot-chrome-profile
BOT_PROFILE_DIRS=
BOT_PROFILE_DIR=

# Chrome executable (optional — auto-detected per OS, falls back to Puppeteer Chromium)
# Mac:     CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows: CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_EXECUTABLE_PATH=

# BMS Integration
BMS_API_URL=http://localhost:4000/api
